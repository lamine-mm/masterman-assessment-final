# ─── Supabase ────────────────────────────────────────────────────────────────
# Used server-side only (API routes + server components)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── ConvertKit (Kit) ─────────────────────────────────────────────────────────
# API key from Kit dashboard → Settings → Developer
CONVERTKIT_API_KEY=your-convertkit-api-key

# Tag IDs (get from Kit → Subscribers → Tags → hover for ID in URL)
CONVERTKIT_TAG_ASSESSMENT_STARTED=00000
CONVERTKIT_TAG_ASSESSMENT_COMPLETE=00000

# One tag per type code (16 total — add as you create them in Kit)
CONVERTKIT_TAG_TYPE_AGSC=00000
CONVERTKIT_TAG_TYPE_AGSP=00000
CONVERTKIT_TAG_TYPE_AGPC=00000
CONVERTKIT_TAG_TYPE_AGPI=00000
CONVERTKIT_TAG_TYPE_ARSC=00000
CONVERTKIT_TAG_TYPE_ARSP=00000
CONVERTKIT_TAG_TYPE_ARPC=00000
CONVERTKIT_TAG_TYPE_ARPI=00000
CONVERTKIT_TAG_TYPE_DGSC=00000
CONVERTKIT_TAG_TYPE_DGSP=00000
CONVERTKIT_TAG_TYPE_DGPC=00000
CONVERTKIT_TAG_TYPE_DGPI=00000
CONVERTKIT_TAG_TYPE_DRSC=00000
CONVERTKIT_TAG_TYPE_DRSP=00000
CONVERTKIT_TAG_TYPE_DRPC=00000
CONVERTKIT_TAG_TYPE_DRPI=00000

# One tag per stage
CONVERTKIT_TAG_STAGE_1=00000
CONVERTKIT_TAG_STAGE_2=00000
CONVERTKIT_TAG_STAGE_3=00000
CONVERTKIT_TAG_STAGE_4=00000

# Sequence ID for result email series (Kit → Sequences → click sequence → ID in URL)
CONVERTKIT_SEQUENCE_RESULT=00000

# ─── App ─────────────────────────────────────────────────────────────────────
# Full URL of the deployed app (no trailing slash) — used for share links + OG
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Calendly or booking link for the "Book a Call" CTA on /thank-you
NEXT_PUBLIC_BOOKING_URL=https://calendly.com/your-link

# ─── Outbound webhooks (optional) ────────────────────────────────────────────
# Generic fanout targets — fires on lead registration
OUTBOUND_WEBHOOK_LEAD_URL=
# Generic fanout targets — fires on assessment completion
OUTBOUND_WEBHOOK_RESULT_URL=
# GoHighLevel CRM — fires on both lead_captured + assessment_completed
OUTBOUND_WEBHOOK_GHL_URL=https://services.leadconnectorhq.com/hooks/0CvkX2cdsiHhKyPPaKB8/webhook-trigger/c265d8ca-0b63-41b6-b2c7-67dc85d496f5
